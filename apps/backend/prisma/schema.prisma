generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  hr
  supervisor
}

enum SheetStatus {
  draft
  submitted
  locked
}

enum AuditAction {
  create
  update
  delete
  disable
  enable
}

enum AuditEntity {
  employee
  department
  sheet
  entry
  user
}

model User {
  id        String   @id @default(uuid()) @db.VarChar(36)
  email     String   @unique @db.VarChar(255)
  password  String   @db.VarChar(255)
  firstName String   @map("first_name") @db.VarChar(255)
  lastName  String   @map("last_name") @db.VarChar(255)
  role      UserRole @default(supervisor)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  sheetsCreated   AttendanceSheet[] @relation("SheetCreatedBy")
  sheetsSubmitted AttendanceSheet[] @relation("SheetSubmittedBy")
  auditLogs       AuditLog[]

  @@map("users")
}

model Department {
  id        String   @id @default(uuid()) @db.VarChar(36)
  code      String   @unique @db.VarChar(50)
  name      String   @db.VarChar(255)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  employeeAssignments EmployeeDepartment[]
  sheets              AttendanceSheet[]

  @@map("departments")
}

model Employee {
  id         String  @id @default(uuid()) @db.VarChar(36)
  code       String  @unique @db.VarChar(50)
  firstName  String  @map("first_name") @db.VarChar(255)
  lastName   String  @map("last_name") @db.VarChar(255)
  hourlyRate Decimal @map("hourly_rate") @db.Decimal(10, 2)
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  departmentAssignments EmployeeDepartment[]
  attendanceEntries     AttendanceEntry[]
  sheetRates            SheetEmployeeRate[]

  @@map("employees")
}

model EmployeeDepartment {
  id           String    @id @default(uuid()) @db.VarChar(36)
  employeeId   String    @map("employee_id") @db.VarChar(36)
  departmentId String    @map("department_id") @db.VarChar(36)
  assignedFrom DateTime  @map("assigned_from") @db.Date
  assignedTo   DateTime? @map("assigned_to") @db.Date
  createdAt    DateTime  @default(now()) @map("created_at")

  employee   Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  department Department @relation(fields: [departmentId], references: [id], onDelete: Restrict)

  @@index([employeeId])
  @@index([departmentId])
  @@index([assignedFrom])
  @@map("employee_departments")
}

model AttendanceSheet {
  id            String      @id @default(uuid()) @db.VarChar(36)
  departmentId  String      @map("department_id") @db.VarChar(36)
  year          Int
  month         Int
  status        SheetStatus @default(draft)
  notes         String?     @db.Text
  createdById   String      @map("created_by_id") @db.VarChar(36)
  submittedById String?     @map("submitted_by_id") @db.VarChar(36)
  submittedAt   DateTime?   @map("submitted_at")
  lockedAt      DateTime?   @map("locked_at")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  department    Department         @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  createdBy     User               @relation("SheetCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  submittedBy   User?              @relation("SheetSubmittedBy", fields: [submittedById], references: [id], onDelete: SetNull)
  entries       AttendanceEntry[]
  employeeRates SheetEmployeeRate[]

  @@unique([departmentId, year, month])
  @@index([year, month])
  @@index([status])
  @@map("attendance_sheets")
}

model SheetEmployeeRate {
  id         String  @id @default(uuid()) @db.VarChar(36)
  sheetId    String  @map("sheet_id") @db.VarChar(36)
  employeeId String  @map("employee_id") @db.VarChar(36)
  realRate   Decimal @map("real_rate") @db.Decimal(10, 2)

  sheet    AttendanceSheet @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  employee Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([sheetId, employeeId])
  @@index([sheetId])
  @@map("sheet_employee_rates")
}

model AttendanceEntry {
  id            String   @id @default(uuid()) @db.VarChar(36)
  sheetId       String   @map("sheet_id") @db.VarChar(36)
  employeeId    String   @map("employee_id") @db.VarChar(36)
  day           Int
  ordinaryHours Decimal? @map("ordinary_hours") @db.Decimal(10, 2)
  overtimeHours Decimal? @map("overtime_hours") @db.Decimal(10, 2)
  absenceCode   String?  @map("absence_code") @db.VarChar(50)
  notes         String?  @db.Text
  updatedAt     DateTime @updatedAt @map("updated_at")

  sheet    AttendanceSheet @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  employee Employee        @relation(fields: [employeeId], references: [id], onDelete: Restrict)

  @@unique([sheetId, employeeId, day])
  @@index([sheetId])
  @@index([employeeId])
  @@map("attendance_entries")
}

model AuditLog {
  id         String      @id @default(uuid()) @db.VarChar(36)
  userId     String?     @map("user_id") @db.VarChar(36)
  action     AuditAction
  entity     AuditEntity
  entityId   String      @map("entity_id") @db.VarChar(36)
  entityName String?     @map("entity_name") @db.VarChar(255)
  before     Json?
  after      Json?
  createdAt  DateTime    @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

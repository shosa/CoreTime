generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  firstName String   @map("first_name")
  lastName  String   @map("last_name")
  role      String   @default("supervisor")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  sheetsCreated   AttendanceSheet[] @relation("SheetCreatedBy")
  sheetsSubmitted AttendanceSheet[] @relation("SheetSubmittedBy")
  auditLogs       AuditLog[]

  @@map("users")
}

model Department {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  employeeAssignments EmployeeDepartment[]
  sheets              AttendanceSheet[]

  @@map("departments")
}

model Employee {
  id         String   @id @default(uuid())
  code       String   @unique
  firstName  String   @map("first_name")
  lastName   String   @map("last_name")
  hourlyRate Decimal  @map("hourly_rate")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  departmentAssignments EmployeeDepartment[]
  attendanceEntries     AttendanceEntry[]
  sheetRates            SheetEmployeeRate[]

  @@map("employees")
}

model EmployeeDepartment {
  id           String    @id @default(uuid())
  employeeId   String    @map("employee_id")
  departmentId String    @map("department_id")
  assignedFrom DateTime  @map("assigned_from")
  assignedTo   DateTime? @map("assigned_to")
  createdAt    DateTime  @default(now()) @map("created_at")

  employee   Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  department Department @relation(fields: [departmentId], references: [id], onDelete: Restrict)

  @@index([employeeId])
  @@index([departmentId])
  @@index([assignedFrom])
  @@map("employee_departments")
}

model AttendanceSheet {
  id            String    @id @default(uuid())
  departmentId  String    @map("department_id")
  year          Int
  month         Int
  status        String    @default("draft")
  notes         String?
  createdById   String    @map("created_by_id")
  submittedById String?   @map("submitted_by_id")
  submittedAt   DateTime? @map("submitted_at")
  lockedAt      DateTime? @map("locked_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  department    Department          @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  createdBy     User                @relation("SheetCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  submittedBy   User?               @relation("SheetSubmittedBy", fields: [submittedById], references: [id], onDelete: SetNull)
  entries       AttendanceEntry[]
  employeeRates SheetEmployeeRate[]

  @@unique([departmentId, year, month])
  @@index([year, month])
  @@index([status])
  @@map("attendance_sheets")
}

model SheetEmployeeRate {
  id         String  @id @default(uuid())
  sheetId    String  @map("sheet_id")
  employeeId String  @map("employee_id")
  realRate   Decimal @map("real_rate")

  sheet    AttendanceSheet @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  employee Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([sheetId, employeeId])
  @@index([sheetId])
  @@map("sheet_employee_rates")
}

model AttendanceEntry {
  id            String   @id @default(uuid())
  sheetId       String   @map("sheet_id")
  employeeId    String   @map("employee_id")
  day           Int
  ordinaryHours Decimal? @map("ordinary_hours")
  overtimeHours Decimal? @map("overtime_hours")
  absenceCode   String?  @map("absence_code")
  notes         String?
  updatedAt     DateTime @updatedAt @map("updated_at")

  sheet    AttendanceSheet @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  employee Employee        @relation(fields: [employeeId], references: [id], onDelete: Restrict)

  @@unique([sheetId, employeeId, day])
  @@index([sheetId])
  @@index([employeeId])
  @@map("attendance_entries")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  action     String
  entity     String
  entityId   String   @map("entity_id")
  entityName String?  @map("entity_name")
  before     String?
  after      String?
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

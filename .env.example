# ============================================================================
# CoreTime - Configurazione Centralizzata
# ============================================================================
# Questo file è un TEMPLATE. Copialo come .env e configura i valori.
#
# Setup rapido:
#   cp .env.example .env
#   nano .env  (modifica i valori)
#
# PREREQUISITO: CoreServices deve essere avviato prima di CoreTime
#   cd ../CoreServices && docker-compose -f docker-compose.services.yml up -d
# ============================================================================

# ----------------------------------------------------------------------------
# APPLICATION
# ----------------------------------------------------------------------------
APP_NAME=CoreTime
APP_PORT=3010
NODE_ENV=development

# URL frontend (con nginx in produzione usa path relativo /api)
APP_URL=http://localhost:3011
NEXT_PUBLIC_API_URL=/api

# ----------------------------------------------------------------------------
# DATABASE (MySQL condiviso da CoreServices → core-mysql)
# In sviluppo locale: usa localhost:3306
# In Docker: usa core-mysql:3306 (gestito dal docker-compose.yml)
# ----------------------------------------------------------------------------
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=coretime
MYSQL_USER=root
MYSQL_PASSWORD=rootpassword
DATABASE_URL=mysql://root:rootpassword@localhost:3306/coretime

# ----------------------------------------------------------------------------
# JWT (JSON Web Tokens)
# ----------------------------------------------------------------------------
JWT_SECRET=coretime-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=8h

# ----------------------------------------------------------------------------
# TIMEZONE
# ----------------------------------------------------------------------------
TZ=Europe/Rome
